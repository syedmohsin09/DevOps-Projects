pipeline {
    agent any

    environment {
        IMAGE_NAME = 'devops-portfolio'
        CONTAINER_NAME = 'portfolio-app'
        PORT = '80'
    }

    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out source code...'
                checkout scm
            }
        }

        stage('Validate Environment') {
            steps {
                echo 'Verifying workspace files...'
                sh 'ls -la DevOps-Project-41/'
            }
        }

        stage('Build Docker Image') {
            steps {
                echo 'Building Docker image for DevOps Portfolio...'
                sh "docker build -t ${IMAGE_NAME}:latest -f DevOps-Project-41/Dockerfile DevOps-Project-41/"
            }
        }

        stage('Deploy to Localhost') {
            steps {
                echo 'Deploying to Localhost...'
                sh """
                    docker stop ${CONTAINER_NAME} || true
                    docker rm ${CONTAINER_NAME} || true
                    docker run -d --name ${CONTAINER_NAME} -p ${PORT}:80 ${IMAGE_NAME}:latest
                """
                echo "Deployment completed! Application running at http://localhost:${PORT}"
            }
        }
    }
}
